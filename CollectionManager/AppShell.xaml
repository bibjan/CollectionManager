<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CollectionManager.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CollectionManager"
    xmlns:views="clr-namespace:CollectionManager.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="#1f1f1f"
    Title="CollectionManager">

    <TabBar>
        <ShellContent
            Title="Strona główna"
            ContentTemplate="{DataTemplate views:MainPage}" />

        <ShellContent 
            Route="CollectionPage" 
            ContentTemplate="{DataTemplate views:CollectionPage}" />
    </TabBar>

</Shell>
